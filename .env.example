# Tube2Txt v3 Environment Configuration
#
# Copy this file to '.env' and fill in your values.
# IMPORTANT: Never commit '.env' with your real key!

# Required for --ai flag. Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Custom path to the SQLite database (default: tube2txt.db in project root)
# TUBE2TXT_DB=/path/to/custom/tube2txt.db
