{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "tube2txt-hub",
    "healthcheckPath": "/healthz",
    "restartPolicyType": "ON_FAILURE"
  },
  "service": {
    "variables": {
      "GEMINI_API_KEY": {
        "description": "Your Google Gemini API Key for AI transcripts and summaries.",
        "required": true
      },
      "TUBE2TXT_DB": {
        "description": "Path to the SQLite database file.",
        "default": "/app/projects/tube2txt.db"
      },
      "PORT": {
        "description": "The port the hub runs on.",
        "default": "8000"
      }
    },
    "volumes": [
      {
        "mountPath": "/app/projects",
        "name": "tube2txt-storage"
      }
    ]
  }
}
